{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.escalation_ladder.v0.2",
  "title": "Escalation ladder v0.2",
  "description": "Tiers for critical result notification; contact modes, max_ack_wait_s, required_fields, requires_readback.",
  "type": "object",
  "required": ["version", "minimum_record_fields", "tiers"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "minimum_record_fields": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Fields required on all comm records (notify/ack)"
    },
    "tiers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["tier_index", "role", "allowed_contact_modes", "max_ack_wait_s"],
        "additionalProperties": true,
        "properties": {
          "tier_index": { "type": "integer", "minimum": 0 },
          "role": { "type": "string" },
          "allowed_contact_modes": {
            "type": "array",
            "items": { "type": "string" },
            "description": "e.g. phone, bleep, electronic"
          },
          "max_ack_wait_s": { "type": "integer", "minimum": 0 },
          "required_fields": {
            "type": "array",
            "items": { "type": "string" }
          },
          "requires_readback": { "type": "boolean", "default": true }
        }
      }
    }
  }
}

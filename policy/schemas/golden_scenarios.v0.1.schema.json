{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.golden_scenarios.v0.1",
  "title": "Golden scenarios structure v0.1",
  "description": "Schema for policy/golden/golden_scenarios.v0.1.yaml (structure only).",
  "type": "object",
  "required": ["golden_suite"],
  "additionalProperties": true,
  "properties": {
    "golden_suite": {
      "type": "object",
      "required": ["scenarios"],
      "additionalProperties": true,
      "properties": {
        "version": { "type": "string" },
        "deterministic": { "type": "object" },
        "depends_on": { "type": "array", "items": { "type": "string" } },
        "runner_contract": { "type": "object" },
        "fixtures": { "type": "object" },
        "scenarios": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["scenario_id", "initial_state", "script"],
            "additionalProperties": true,
            "properties": {
              "scenario_id": { "type": "string" },
              "title": { "type": "string" },
              "post_run_hooks": {
                "type": "array",
                "description": "Optional hooks run after script (before post_run): EXPORT_RECEIPTS, VERIFY_BUNDLE, EXPORT_FHIR. Deterministic for fixed seed; use stable temp paths.",
                "items": { "type": "string", "enum": ["EXPORT_RECEIPTS", "VERIFY_BUNDLE", "EXPORT_FHIR"] }
              },
              "post_run": {
                "type": "array",
                "description": "Optional post-episode actions (export, assert). Run after script steps succeed.",
                "items": {
                  "type": "object",
                  "required": ["action"],
                  "additionalProperties": true,
                  "properties": {
                    "action": { "type": "string", "enum": ["EXPORT_RECEIPTS", "EXPORT_FHIR", "ASSERT_FILE_EXISTS", "ASSERT_SCHEMA_VALID"] },
                    "out_dir": { "type": "string" },
                    "out_filename": { "type": "string" },
                    "path": { "type": "string" },
                    "schema": { "type": "string" }
                  }
                }
              },
              "initial_state": {
                "type": "object",
                "required": [],
                "additionalProperties": true,
                "properties": {
                  "system": { "type": "object" },
                  "agents": { "type": "array" },
                  "specimens": { "type": "array" },
                  "tokens": { "type": "array" }
                }
              },
              "script": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["event_id", "t_s", "agent_id", "action_type", "args", "reason_code", "token_refs"],
                  "additionalProperties": true,
                  "properties": {
                    "event_id": { "type": "string" },
                    "t_s": { "type": "integer" },
                    "agent_id": { "type": "string" },
                    "action_type": { "type": "string" },
                    "args": { "type": "object" },
                    "reason_code": {},
                    "token_refs": { "type": "array" },
                    "expect": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

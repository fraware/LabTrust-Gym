{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.enforcement_map.v0.1",
  "title": "Enforcement map v0.1",
  "description": "Policy-driven enforcement rules: match violations, apply throttle | kill_switch | freeze_zone | forensic_freeze with optional escalation.",
  "type": "object",
  "required": ["version", "rules"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "enforcement_map_id": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "match", "action"],
        "additionalProperties": true,
        "properties": {
          "rule_id": { "type": "string" },
          "match": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "invariant_id": { "type": "string" },
              "severity": { "type": "string" },
              "scope": { "type": "string" }
            }
          },
          "action": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["throttle_agent", "kill_switch", "freeze_zone", "forensic_freeze"]
              },
              "duration_s": { "type": "integer" },
              "zone_id": { "type": "string" },
              "target_type": { "type": "string" }
            }
          },
          "escalation": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["violation_count_min", "action"],
              "additionalProperties": true,
              "properties": {
                "violation_count_min": { "type": "integer" },
                "action": {
                  "type": "object",
                  "required": ["type"],
                  "additionalProperties": true,
                  "properties": {
                    "type": { "type": "string" },
                    "duration_s": { "type": "integer" },
                    "zone_id": { "type": "string" },
                    "target_type": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}

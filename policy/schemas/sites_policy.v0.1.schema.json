{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.sites_policy.v0.1",
  "title": "Sites policy v0.1",
  "description": "Multi-site topology, site graph, allowed routes, transport_time and temp_drift.",
  "type": "object",
  "required": ["sites_policy"],
  "additionalProperties": true,
  "properties": {
    "sites_policy": {
      "type": "object",
      "required": ["version", "sites", "routes"],
      "additionalProperties": true,
      "properties": {
        "version": { "type": "string" },
        "sites": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["site_id", "name"],
            "properties": {
              "site_id": { "type": "string" },
              "name": { "type": "string" },
              "zone_ids": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "site_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from_site", "to_site"],
            "properties": {
              "from_site": { "type": "string" },
              "to_site": { "type": "string" },
              "enabled": { "type": "boolean" }
            }
          }
        },
        "routes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["route_id", "from_site", "to_site", "transport_time_mean_s"],
            "properties": {
              "route_id": { "type": "string" },
              "from_site": { "type": "string" },
              "to_site": { "type": "string" },
              "transport_time_mean_s": { "type": "integer", "minimum": 0 },
              "transport_time_std_s": { "type": "integer", "minimum": 0 },
              "temp_drift_model": { "type": "string" },
              "temp_drift_max_c": { "type": "number" },
              "temp_band": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

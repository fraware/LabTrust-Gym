{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.study_spec.v0.1",
  "title": "Study spec v0.1",
  "description": "Schema for study spec YAML: task, episodes, ablations, agent_config.",
  "type": "object",
  "required": ["task", "episodes", "seed_base"],
  "additionalProperties": true,
  "properties": {
    "task": {
      "type": "string",
      "enum": ["TaskA", "TaskB", "TaskC", "TaskA_ThroughputSLA", "TaskB_STATInsertionUnderLoad", "TaskC_QCFailCascade"]
    },
    "episodes": { "type": "integer", "minimum": 1 },
    "seed_base": { "type": "integer" },
    "timing_mode": {
      "type": "string",
      "enum": ["explicit", "simulated"],
      "default": "explicit"
    },
    "ablations": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "trust_skeleton": {
          "type": "array",
          "items": { "type": "string", "enum": ["on", "off"] }
        },
        "rbac": {
          "type": "array",
          "items": { "type": "string", "enum": ["coarse", "fine"] }
        },
        "dual_approval": {
          "type": "array",
          "items": { "type": "string", "enum": ["on", "off"] }
        },
        "log_granularity": {
          "type": "array",
          "items": { "type": "string", "enum": ["minimal", "full"] }
        }
      }
    },
    "agent_config": {
      "type": "string",
      "enum": ["scripted_ops", "scripted_runner", "random", "placeholder"],
      "default": "scripted_runner"
    }
  }
}

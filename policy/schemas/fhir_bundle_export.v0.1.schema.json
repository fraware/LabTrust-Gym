{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.fhir_bundle_export.v0.1",
  "title": "LabTrust FHIR Bundle Export Contract v0.1",
  "description": "Minimal structural contract for FHIR R4 Bundle export (not full FHIR validation).",
  "type": "object",
  "required": ["resourceType", "type", "entry"],
  "properties": {
    "resourceType": { "type": "string", "const": "Bundle" },
    "type": { "type": "string", "const": "collection" },
    "meta": {
      "type": "object",
      "properties": {
        "tag": { "type": "array", "items": { "type": "object" } },
        "extension": { "type": "array", "items": { "type": "object" } }
      }
    },
    "entry": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fullUrl", "resource"],
        "properties": {
          "fullUrl": { "type": "string" },
          "resource": {
            "type": "object",
            "required": ["resourceType", "id"],
            "properties": {
              "resourceType": { "type": "string", "enum": ["Specimen", "Observation", "DiagnosticReport"] },
              "id": { "type": "string" }
            }
          }
        }
      }
    }
  }
}

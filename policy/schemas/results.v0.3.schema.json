{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.results.v0.3",
  "title": "LabTrust Benchmark Results v0.3",
  "description": "Paper-grade results: extends v0.2 with optional quantiles, confidence intervals, and simulated-mode distributions. All v0.2 fields unchanged; v0.3 adds optional metrics for reporting.",
  "type": "object",
  "required": ["schema_version", "task", "seeds", "episodes", "agent_baseline_id"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "string", "const": "0.3" },
    "task": { "type": "string", "description": "Task name (e.g. TaskA, TaskB, TaskC, TaskD, TaskE, TaskF)" },
    "seeds": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "Episode seeds (deterministic reproducibility)"
    },
    "policy_fingerprint": { "type": ["string", "null"] },
    "partner_id": { "type": ["string", "null"] },
    "git_sha": { "type": ["string", "null"], "description": "Git commit hash at run time" },
    "agent_baseline_id": {
      "type": "string",
      "description": "Baseline identifier: scripted_ops_v1, adversary_v1, insider_v1, ppo_v1, llm_safe_v1, etc."
    },
    "num_episodes": { "type": "integer" },
    "base_seed": { "type": "integer" },
    "config": { "type": "object" },
    "policy_versions": { "type": "object" },
    "episodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["seed", "metrics"],
        "properties": {
          "seed": { "type": "integer" },
          "metrics": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "throughput": { "type": "integer" },
              "p50_turnaround_s": { "type": ["number", "null"] },
              "p95_turnaround_s": { "type": ["number", "null"] },
              "on_time_rate": { "type": ["number", "null"] },
              "violations_by_invariant_id": { "type": "object" },
              "blocked_by_reason_code": { "type": "object" },
              "critical_communication_compliance_rate": { "type": ["number", "null"] },
              "detection_latency_s": { "type": ["number", "null"] },
              "containment_success": { "type": ["boolean", "null"] },
              "tokens_minted": { "type": "integer" },
              "tokens_consumed": { "type": "integer" },
              "holds_count": { "type": "integer" },
              "steps": { "type": "integer" },
              "transport_consignment_count": { "type": "integer" },
              "transport_temp_excursions": { "type": "integer" },
              "coc_breaks_count": { "type": "integer" },
              "turnaround_quantiles_s": {
                "type": "object",
                "description": "Quantiles of turnaround time (seconds): p10, p25, p50, p75, p90",
                "properties": {
                  "p10": { "type": "number" },
                  "p25": { "type": "number" },
                  "p50": { "type": "number" },
                  "p75": { "type": "number" },
                  "p90": { "type": "number" }
                }
              },
              "throughput_ci_95": {
                "type": "object",
                "description": "95% CI for throughput (count): lower, upper",
                "properties": {
                  "lower": { "type": "number" },
                  "upper": { "type": "number" }
                }
              },
              "p95_turnaround_s_ci_95": {
                "type": "object",
                "description": "95% CI for p95 turnaround (seconds): lower, upper",
                "properties": {
                  "lower": { "type": "number" },
                  "upper": { "type": "number" }
                }
              },
              "device_utilization": {
                "type": "object",
                "description": "Per-device utilization (simulated mode): device_id -> [0,1]",
                "additionalProperties": { "type": "number" }
              },
              "device_queue_length_mean": {
                "type": "object",
                "description": "Per-device mean queue length (simulated mode)",
                "additionalProperties": { "type": "number" }
              },
              "device_queue_length_max": {
                "type": "object",
                "description": "Per-device max queue length (simulated mode)",
                "additionalProperties": { "type": "integer" }
              }
            }
          }
        }
      }
    }
  }
}

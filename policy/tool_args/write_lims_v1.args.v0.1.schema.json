{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.write_lims_v1.args.v0.1",
  "title": "write_lims_v1 arguments",
  "description": "Argument schema for write_lims_v1: typed and range-checked.",
  "type": "object",
  "required": ["accession_id", "field", "value"],
  "additionalProperties": false,
  "properties": {
    "accession_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "description": "Accession identifier to write in LIMS."
    },
    "field": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "description": "Field name to update."
    },
    "value": {
      "type": "string",
      "minLength": 0,
      "maxLength": 4096,
      "description": "Value to write."
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "labtrust.prompt_registry.v0.1",
  "title": "Prompt registry v0.1",
  "description": "Schema for policy/llm/prompt_registry.v0.1.yaml (versioned prompt templates for LLM agents).",
  "type": "object",
  "required": ["version", "prompts"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "prompt_id",
          "version",
          "system_template",
          "developer_template",
          "user_template"
        ],
        "additionalProperties": true,
        "properties": {
          "prompt_id": { "type": "string" },
          "version": { "type": "string" },
          "system_template": { "type": "string" },
          "developer_template": { "type": "string" },
          "user_template": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
